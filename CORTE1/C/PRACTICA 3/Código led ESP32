const int pinEntrada = 12; 
int estado = 0;           
 
void setup() {
  pinMode(pinEntrada, INPUT); 
  pinMode(19, OUTPUT);
}
 
void loop() {
  estado = digitalRead(pinEntrada);
  if(estado == 0){
    digitalWrite(19, HIGH);
  }
  else {
    digitalWrite(19, LOW);
  }
  delay(100);                     
}
